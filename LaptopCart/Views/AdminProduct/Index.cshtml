@model IEnumerable<Product>

<table class="table-bordered table-striped">
    <thead>
        <tr>
            <th>Product ID</th>
            <th>Product Name</th>
            <th>Price</th>
            <th>Image</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Name</td>
                <td>@product.Description</td>
                <td>@product.Price</td>
                <td>
                    @if (!string.IsNullOrEmpty(product.ImagePath))
                    {
                        <img src="@Url.Content(product.ImagePath)" alt="@product.Name" width="100" height="100" />
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-warning"><i class="bi bi-pencil-square"></i>Edit</a> |
                    <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i>Delete</a>
                </td>
            </tr>
        }
    </tbody>

</table>