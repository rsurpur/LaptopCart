@model Product

<div class="card border-0">
    <div class="card-header ms-0 text-white" style="background-color:darkred">
        <h1 class="p-2 text-center"> Delete Product</h1>
    </div>
    <div class="card-body mt-3">
        <h5 class="text-danger text-center mb-4">Are you sure you want to delete this product</h5>

        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="" readonly disabled/>
                <label class="ms-2 text-muted">Name</label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Description" class="form-control" placeholder="" readonly disabled/>
                <label class="ms-2 text-muted">Description</label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Price" class="form-control" placeholder="" readonly disabled/>
                <label class="ms-2 text-muted">Price</label>
            </div>
            <div class="mb-3 text-muted">
                <label class="form-label">Product Image</label>
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Url.Content(Model.ImagePath)" alt="@Model.Name" width="150" height="150" />
                }
            </div>
                <input type="hidden" asp-for="Id"/>
            <div class="row justify-content-between">
                <div class="col-4">
                    <a asp-action="Index" class="btn btn-secondary w-100">Back</a>
                </div>
                <div class="col-6">
                    <button type="submit" class="btn btn-danger w-100">Yes,Delete</button>
                </div>
            </div>
            </form>
    </div>

</div>